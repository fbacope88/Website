{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/creative-web-studio run build",
  "outputDirectory": "artifacts/creative-web-studio/dist/public",
  "functions": {
    "artifacts/api-server/dist/index.mjs": {
      "runtime": "nodejs22.x",
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/artifacts/api-server/dist/index.mjs"
    },
    {
      "source": "/blog/:slug",
      "destination": "/artifacts/api-server/dist/index.mjs"
    },
    {
      "source": "/blog",
      "destination": "/artifacts/api-server/dist/index.mjs"
    },
    {
      "source": "/((?!assets|favicon).*)",
      "destination": "/index.html"
    }
  ]
}
